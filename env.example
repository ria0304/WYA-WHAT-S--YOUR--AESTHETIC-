# ============================================================
#  WYA — What's Your Aesthetic
#  Environment Variables — copy this file to .env and fill in
# ============================================================

# ------------------------------------------------------------
# 🔐  AUTH / SECURITY
# ------------------------------------------------------------

# Secret key used to sign JWT tokens (make this long & random)
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-jwt-key-change-this


# ------------------------------------------------------------
# 🤖  AI / LLM APIs
# ------------------------------------------------------------

# OpenRouter API key — used for Travel Tab (Trip Curator)
# Free tier available, no credit card needed
# Sign up at: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here


# ------------------------------------------------------------
# 🗺️  MAPS & LOCATION
# ------------------------------------------------------------

# Geoapify API key — used for location search & weather
# Free tier: 3,000 requests/day
# Sign up at: https://www.geoapify.com
GEOAPIFY_API_KEY=your-geoapify-api-key-here


# ------------------------------------------------------------
# 📧  EMAIL (Gmail SMTP)
# ------------------------------------------------------------

# Gmail address used to send emails from the app
WYA_GMAIL_ADDRESS=your-email@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# Generate at: myaccount.google.com → Security → 2FA → App Passwords
WYA_GMAIL_APP_PASS=your-16-char-app-password

# Base URL of your app (used in email links)
WYA_APP_BASE_URL=http://localhost:5173


# ------------------------------------------------------------
# 🔔  PUSH NOTIFICATIONS (Web Push / VAPID)
# ------------------------------------------------------------

# VAPID keys are used to send browser push notifications
# Generate a key pair with:
#   npx web-push generate-vapid-keys
WYA_VAPID_PUBLIC_KEY=your-vapid-public-key-here
WYA_VAPID_PRIVATE_KEY=your-vapid-private-key-here

# Must be a mailto: address
WYA_VAPID_CLAIMS_EMAIL=mailto:hello@wya.app


# ------------------------------------------------------------
# 🗄️  DATABASE
# ------------------------------------------------------------

# SQLite is used by default (wya.db created automatically)
# No config needed for local dev.
# If you switch to PostgreSQL in production, set this:
# DATABASE_URL=postgresql://user:password@localhost:5432/wya


# ------------------------------------------------------------
# 🌐  APP
# ------------------------------------------------------------

# Set to "production" in prod, "development" locally
NODE_ENV=development

# Frontend dev server port (Vite)
VITE_PORT=3000

# Backend API port (FastAPI / Uvicorn)
API_PORT=8000
